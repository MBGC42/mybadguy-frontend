# MyBadGuy — Cloudflare Pages security headers
# Applied to every response from mybadguy.com
# Docs: developers.cloudflare.com/pages/configuration/headers

/*
  # Prevent clickjacking — no iframes from external sites
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Limit referrer information sent to external sites
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features we don't use
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=()

  # Force HTTPS for 1 year, include subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy
  # - default-src: nothing by default
  # - script-src: no inline scripts, no eval — only our own origin
  # - style-src: our origin + Google Fonts
  # - font-src: Google Fonts CDN only
  # - img-src: our origin + data URIs (inline SVG favicons)
  # - connect-src: our API subdomain only
  # - frame-src: Cloudflare Turnstile only (used on scan save)
  # - object-src: nothing
  # - base-uri: our origin only (prevents base tag hijacking)
  # - form-action: our origin only
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src https://api.mybadguy.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

  # Cross-origin policies
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin

  # Cache control for HTML pages — always revalidate
  Cache-Control: no-cache, must-revalidate
